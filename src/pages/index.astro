---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../site";
import { formatDate, getPublishedPosts, postUrl } from "../utils/posts";

const posts = await getPublishedPosts();
---

<BaseLayout title={site.title} description={site.description}>
  <section class="intro">
    <h1>{site.title}</h1>
    <p>{site.description}</p>
  </section>

  {
    posts.length > 0 ? (
      <ol class="post-list">
        {posts.map((post) => (
          <li class="post-item">
            <h2>
              <a href={postUrl(post)}>{post.data.title}</a>
            </h2>
            <p class="post-meta">
              <time datetime={post.data.date.toISOString()}>
                {formatDate(post.data.date)}
              </time>
              {post.data.tags.map((tag) => (
                <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>
                  {tag}
                </a>
              ))}
            </p>
            {post.data.description && <p>{post.data.description}</p>}
          </li>
        ))}
      </ol>
    ) : (
      <p class="empty">还没有文章。可以去后台写第一篇，或把文件放进 incoming/ 后运行导入脚本。</p>
    )
  }
</BaseLayout>
